{
  "name": "iobroker.logsearch",
  "version": "0.0.1",
  "description": "Search ioBroker log files by time range, level and text",
  "author": {
    "name": "Disaster123",
    "email": "stefan-iobroker@prie.be"
  },
  "homepage": "https://github.com/Disaster123/ioBroker.logsearch",
  "license": "MIT",
  "keywords": [
    "log",
    "search",
    "full log search",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Disaster123/ioBroker.logsearch.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.0",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/adapter-react-v5": "^7.7.2",
    "@iobroker/testing": "^5.2.2",
    "@mui/material": "^5.16.14",
    "@mui/styles": "^5.16.14",
    "@tsconfig/node20": "^20.1.9",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.41",
    "@types/proxyquire": "^1.3.31",
    "@types/react": "^17.0.92",
    "@types/react-dom": "^17.0.26",
    "@types/sinon": "^21.0.1",
    "@types/sinon-chai": "^3.2.12",
    "chai": "^4.5.0",
    "chai-as-promised": "^7.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "mocha": "^11.7.6",
    "proxyquire": "^2.1.3",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "sinon": "^22.0.0",
    "sinon-chai": "^3.7.0",
    "typescript": "~5.0.4"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "admin/build/",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "prebuild": "rimraf admin/build",
    "build": "build-adapter react",
    "watch": "build-adapter react --watch",
    "prebuild:react": "rimraf admin/build",
    "build:react": "build-adapter react",
    "watch:react": "build-adapter react --watch",
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint --ext .js,.jsx .",
    "translate": "translate-adapter",
    "release": "release-script"
  },
  "bugs": {
    "url": "https://github.com/Disaster123/ioBroker.logsearch/issues"
  },
  "readmeFilename": "README.md"
}
